# CareOne runtime configuration

# Optional. Default is deterministic offline-safe mode for reliable demos.
# Set to 1 only when you want live Gemini calls and have network/API access.
CAREONE_LIVE_LLM=0

# Optional Gemini configuration for live mode.
GEMINI_API_KEY=
CAREONE_MODEL=gemini-1.5-flash

# Optional MongoDB configuration. Leave empty or placeholder to use local JSON fallback.
MONGO_URI=
MONGO_DB_NAME=CareOne

# Local/deployment server settings.
CAREONE_HOST=127.0.0.1
CAREONE_PORT=8501
